# ==========================================
# Docker Compose CLI Settings
# ==========================================
# Delegate builds to Buildx Bake for parallel building and better caching
COMPOSE_BAKE=true

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpassword
POSTGRES_DB=gis_dev

# ==========================================
# Host Machine Ports
# ==========================================
HOST_PORT_API=80
HOST_PORT_INGESTION=81

# ==========================================
# Application Settings
# ==========================================
LOG_LEVEL=DEBUG

# ==========================================
# BUILD CONFIGURATION: API SERVICE
# ==========================================
API_TASK_MODULES=gcp_provision,elasticsearch
API_MODULES=db_config,db,datastore,catalog,stac,tiles,gcp,processes,tasks,crs,httpx,proxy,auth,apikey,stats,gdal,spanner,elasticsearch
API_EXTENSION_MODULES=web,logs,stats,events,assets,configs,stac,features,processes,tasks,gcp,httpx,proxy,gdal,tiles,maps,wfs,styles,crs,dwh,apikey,auth,template,datamind,permissions,search

# ==========================================
# BUILD CONFIGURATION: INGESTION SERVICE
# ==========================================
WORKER_TASK_MODULES=ingestion,export_features,dwh_join,tiles_preseed,gdal
WORKER_MODULES=db_config,db,datastore,catalog,stac,tiles,gcp,processes,tasks,crs,gdal,httpx,elasticsearch
WORKER_EXTENSION_MODULES=web,gcp,processes,tasks,httpx,logs,events,stats,tiles,search

# ==========================================
# TEST CONFIGURATION (pipeline)
# ==========================================
TEST_API_TASK_MODULES=gcp_cloud_runner
TEST_API_MODULES=db_config,db,datastore,catalog,stac,tiles,processes,tasks,crs,httpx,proxy,auth,apikey,stats,gdal,spanner
TEST_API_EXTENSION_MODULES=web,logs,stats,events,assets,configs,stac,features,processes,tasks,httpx,proxy,gdal,tiles,maps,wfs,styles,crs,dwh,apikey,auth,template,datamind,permissions

TEST_WORKER_TASK_MODULES=ingestion,export_features,dwh_join,tiles_preseed,gdal
TEST_WORKER_MODULES=db_config,db,datastore,catalog,stac,tiles,processes,tasks,crs,gdal,httpx
TEST_WORKER_EXTENSION_MODULES=web,processes,tasks,httpx,logs,events,stats,tiles