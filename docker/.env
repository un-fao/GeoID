# ==========================================
# Docker Compose CLI Settings
# ==========================================
# Delegate builds to Buildx Bake for parallel building and better caching
COMPOSE_BAKE=true

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpassword
POSTGRES_DB=gis_dev

# ==========================================
# Host Machine Ports
# ==========================================
HOST_PORT_API=80
HOST_PORT_INGESTION=81

# ==========================================
# Application Settings
# ==========================================
LOG_LEVEL=DEBUG

# ==========================================
# BUILD CONFIGURATION (SCOPE)
# ==========================================
# SCOPE selects which pyproject.toml extras to install for each service.
# Reference the named compositions in pyproject.toml [project.optional-dependencies].
#
# Services use async-db (db_async = db_config + db).
# Tasks/Jobs use sync-db (task_base already includes db_sync = db_config + datastore).
#
# ---- Service scopes (long-running API processes, async-db) ----
# api_open  = full catalog, NO auth/apikey (open for testing)
# api_catalog = full catalog WITH auth/apikey
# api_full  = all features (monolithic dev)
API_SCOPE=api_open
GEOID_SCOPE=geoid_service
WORKER_SCOPE=worker_local

# ---- Test scope ----
TEST_SCOPE=test,all