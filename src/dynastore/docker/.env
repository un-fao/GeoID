# ==========================================
# GeoID / DynaStore — Docker Compose Environment
# ==========================================
# Copy this file to `.env` in this directory and adjust values:
#   cp .env.example .env
#
# This is the user-facing entrypoint for tweaking the composition without
# editing the compose files. It controls:
#   - DB credentials and port mapping
#   - Per-service SCOPE (which pyproject.toml extras each service installs)
#   - Host port mappings
#   - IdP (Keycloak) endpoints and credentials
#   - Log level and misc app behaviour

# ==========================================
# Docker Compose CLI Settings
# ==========================================
# Delegate builds to Buildx Bake for parallel building and better caching
COMPOSE_BAKE=true

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpassword
POSTGRES_DB=gis_dev

# ==========================================
# Host Machine Ports
# ==========================================
HOST_PORT_CATALOG=80
HOST_PORT_WORKER=81
HOST_PORT_TOOLS=8082
HOST_PORT_MAPS=8083

# ==========================================
# Application Settings
# ==========================================
LOG_LEVEL=DEBUG

# ==========================================
# BUILD CONFIGURATION (SCOPE)
# ==========================================
# SCOPE selects which pyproject.toml extras to install for each service.
# Reference the scope_* compositions in pyproject.toml [project.optional-dependencies].
#
# Services use async-db (db_async = db_config + db).
# Tasks/Jobs use sync-db (task_base already includes db_sync = db_config + datastore).
#
# ---- Service scopes (long-running API processes, async-db) ----
# catalog = no auth (open for testing)
# geoid   = catalog + auth/iam + geoid UI (maps to geospatial-auth in cloud)
# worker  = background task processor + monitoring UI
# tools   = proxy + template tools service
# maps    = map tiles/styles service, no auth
CATALOG_SCOPE=scope_catalog
GEOID_SCOPE=scope_geoid
WORKER_SCOPE=scope_worker
TOOLS_SCOPE=scope_tools
MAPS_SCOPE=scope_maps

# ---- Test scope ----
TEST_SCOPE=test,all

# ==========================================
# Identity Provider (IdP)
# ==========================================
# ============================================================================
# !!  THESE ARE LOCAL-DEV DEFAULTS — DO NOT USE IN PRODUCTION OR REVIEW  !!
# ----------------------------------------------------------------------------
# The values below match the committed `keycloak/realm-export.json` so that a
# fresh `docker compose up` from this repo produces a working, browseable
# stack with built-in test users.  Production / review deployments MUST
# override every secret below via environment variables (Cloud Run secrets,
# Kubernetes secrets, Astronomer / Airflow Connections, etc.) — see
# `src/dynastore/modules/iam/identity_providers/KEYCLOAK_SETUP.md` for the
# canonical override list and per-environment recipes.
# ============================================================================
#
# Admin console: http://localhost:${HOST_PORT_KEYCLOAK}/  (admin / KEYCLOAK_ADMIN_PASSWORD)
#
# Test users (built into keycloak/realm-export.json — passwords match usernames):
#   sysadmin   / sysadmin    — role: sysadmin (full platform access)
#   admin      / admin       — role: admin    (+ catalog_admin client role)
#   user       / user        — role: user
#   viewer     / viewer      — role: viewer
#   testadmin  / testadmin   — role: admin    (+ catalog_admin) — kept for legacy notebooks/tests
#   testuser   / testuser    — role: user                       — kept for legacy notebooks/tests
#   testviewer / testviewer  — role: viewer                     — kept for legacy notebooks/tests
# (One-keystroke sign-in during dev. Change via the Keycloak admin console or
#  `kcadm.sh set-password` for a long-lived environment.)
#
# IDP_TYPE selects the backend implementation (currently only "oidc"; "saml2" planned).
# Any OIDC-compliant IdP works: Keycloak, Okta, Auth0, Azure AD, Google, etc.
#
# IDP_ISSUER_URL: backend-internal URL the API uses to reach the IdP for
#   OIDC discovery, JWKS fetch, token exchange, userinfo. Must be reachable
#   from inside the API container (in compose: `http://keycloak:8080`).
# IDP_PUBLIC_URL: browser-facing IdP URL. Used for the authorization redirect
#   AND as the expected `iss` claim in tokens — `oidc_identity.py:200`
#   accepts `iss` matching either IDP_PUBLIC_URL or IDP_ISSUER_URL.
#   Defaults to IDP_ISSUER_URL when unset. With Keycloak's
#   KC_HOSTNAME_BACKCHANNEL_DYNAMIC=true, tokens carry `iss=IDP_PUBLIC_URL`.
IDP_TYPE=oidc
IDP_ISSUER_URL=http://keycloak:8080/realms/geoid
IDP_PUBLIC_URL=http://localhost:8180/realms/geoid
IDP_CLIENT_ID=geoid-api
# Confidential-client secret. The value below is the LOCAL-DEV fixture that
# matches `keycloak/realm-export.json` so the API can complete the OIDC code
# exchange against the local realm out of the box. Production and review
# environments MUST override this via the IDP_CLIENT_SECRET env var with a
# real, long-lived secret pulled from a secret manager.
IDP_CLIENT_SECRET=geoid-api-secret
HOST_PORT_KEYCLOAK=8180
# Keycloak container admin password (used for the `master` realm admin).
# Local-dev default. Override KEYCLOAK_ADMIN_PASSWORD in real environments.
KEYCLOAK_ADMIN_PASSWORD=admin

# ==========================================
# Local-only: GCP self-URL shim
# ==========================================
# On Cloud Run, K_SERVICE is set automatically and get_self_url() uses it.
# Locally there is no K_SERVICE, so provide SERVICE_URL to satisfy the check.
# Without this, gcp_provision_catalog fails → catalog is hard-deleted ~60s
# after creation.
SERVICE_URL=http://localhost:8080

# ==========================================
# OpenSearch / Elasticsearch Configuration
# ==========================================
ES_HOST=elasticsearch
ES_PORT=9200
