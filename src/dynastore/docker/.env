# ==========================================
# GeoID / DynaStore — Docker Compose Environment
# ==========================================
# Copy this file to `.env` in this directory and adjust values:
#   cp .env.example .env
#
# This is the user-facing entrypoint for tweaking the composition without
# editing the compose files. It controls:
#   - DB credentials and port mapping
#   - Per-service SCOPE (which pyproject.toml extras each service installs)
#   - Host port mappings
#   - IdP (Keycloak) endpoints and credentials
#   - Log level and misc app behaviour

# ==========================================
# Docker Compose CLI Settings
# ==========================================
# Delegate builds to Buildx Bake for parallel building and better caching
COMPOSE_BAKE=true

# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=gis_dev

# ==========================================
# Host Machine Ports
# ==========================================
HOST_PORT_CATALOG=80
HOST_PORT_WORKER=81
HOST_PORT_TOOLS=8082
HOST_PORT_MAPS=8083

# ==========================================
# Application Settings
# ==========================================
LOG_LEVEL=DEBUG

# ==========================================
# BUILD CONFIGURATION (SCOPE)
# ==========================================
# SCOPE selects which pyproject.toml extras to install for each service.
# Reference the scope_* compositions in pyproject.toml [project.optional-dependencies].
#
# Services use async-db (db_async = db_config + db).
# Tasks/Jobs use sync-db (task_base already includes db_sync = db_config + datastore).
#
# ---- Service scopes (long-running API processes, async-db) ----
# catalog = no auth (open for testing)
# geoid   = catalog + auth/iam + geoid UI (maps to geospatial-auth in cloud)
# worker  = background task processor + monitoring UI
# tools   = proxy + template tools service
# maps    = map tiles/styles service, no auth
CATALOG_SCOPE=scope_catalog
GEOID_SCOPE=scope_geoid
WORKER_SCOPE=scope_worker
TOOLS_SCOPE=scope_tools
MAPS_SCOPE=scope_maps

# ---- Test scope ----
TEST_SCOPE=test,all

# ==========================================
# Identity Provider (IdP)
# ==========================================
# Admin console: http://localhost:${HOST_PORT_KEYCLOAK}/  (admin / KEYCLOAK_ADMIN_PASSWORD)
#
# Test users (from keycloak/realm-export.json):
#   testadmin  / testpassword  — roles: admin, catalog_admin
#   testuser   / testpassword  — role:  user
#   testviewer / testpassword  — role:  viewer
#
# IDP_TYPE selects the backend implementation (currently only "oidc"; "saml2" planned).
# Any OIDC-compliant IdP works: Keycloak, Okta, Auth0, Azure AD, Google, etc.
#
# IDP_ISSUER_URL: backend-internal URL for OIDC discovery, token validation, userinfo.
# IDP_PUBLIC_URL: browser-facing URL for the authorization redirect.
IDP_TYPE=oidc
IDP_ISSUER_URL=http://keycloak:8080/realms/geoid
IDP_PUBLIC_URL=http://localhost:8180/realms/geoid
IDP_CLIENT_ID=geoid-api
IDP_CLIENT_SECRET=<change-me>
HOST_PORT_KEYCLOAK=8180
# Keycloak container admin credentials (not used by the app):
KEYCLOAK_ADMIN_PASSWORD=<change-me>

# ==========================================
# Local-only: GCP self-URL shim
# ==========================================
# On Cloud Run, K_SERVICE is set automatically and get_self_url() uses it.
# Locally there is no K_SERVICE, so provide SERVICE_URL to satisfy the check.
# Without this, gcp_provision_catalog fails → catalog is hard-deleted ~60s
# after creation.
SERVICE_URL=http://localhost:8080

# ==========================================
# OpenSearch / Elasticsearch Configuration
# ==========================================
ES_HOST=elasticsearch
ES_PORT=9200
