{
  "versioning_behavior": "create_new_version",
  "collection_type": "VECTOR",
  "attribute_ex": "",
  "partitioning": {
    "enabled": false,
    "strategy": "LIST",
    "partition_column": "string",
    "interval": "monthly",
    "pre_create_intervals": 3,
    "retention": {
      "enabled": false,
      "interval": "12 months",
      "schedule": "0 3 * * 0"
