    "target_srid": 4326,
    "srid_mismatch_policy": "transform",
    "target_dimension": "force_2d",
    "remove_redundant_vertices": false,
    "write_bbox": true
  },
  "h3_resolutions": [],
  "s2_resolutions": [],
  "indexing": {
    "spatial_index_method": "GIST",
    "temporal_index_method": "GIST",
    "column_indices": [],
    "attribute_indices": []
  }
}
