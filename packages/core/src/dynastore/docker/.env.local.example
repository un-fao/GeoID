# .env.local — local overrides (gitignored, never committed)
#
# Copy this file to .env.local in this directory (or any parent directory up to
# the project root). Notebooks use find_dotenv() to walk up from their location,
# so a single .env.local at the repo root covers all notebooks.
#
# Values here override the defaults in .env. Shell-exported vars always win
# over .env.local (load_dotenv uses override=False).
#
# ── Targeting a review / staging environment ───────────────────────────────
#
# DYNASTORE_BASE_URL is the only var you must override for a remote target.
# Do NOT put raw bearer tokens here — they expire. Instead set the IDP vars
# below so notebooks auto-fetch a fresh token via client_credentials.

DYNASTORE_BASE_URL=https://<review-host>

# IDP client with client_credentials grant enabled (service account).
# Notebooks read these to mint a short-lived token automatically at startup.
# The docker .env already has IDP_* set for the local Keycloak — you only
# need to override them when pointing at a remote environment.
IDP_PUBLIC_URL=https://<keycloak-host>/realms/<realm>
IDP_CLIENT_ID=<service-client-id>
IDP_CLIENT_SECRET=<service-client-secret>

# ── Sysadmin operations (catalog creation, platform admin) ─────────────────
#
# Some notebooks require sysadmin-level access. If the service client above
# does not have sysadmin privileges, set this to a manually-minted token.
# Alternatively, leave unset — notebooks will fall back to DYNASTORE_TOKEN.
# DYNASTORE_SYSADMIN_TOKEN=<short-lived-sysadmin-token>

# ── Local Docker (defaults already in .env — only override if port differs) ─
# DYNASTORE_BASE_URL=http://localhost:8080
# IDP_PUBLIC_URL=http://localhost:8180/realms/geoid
# IDP_CLIENT_ID=geoid-api
# IDP_CLIENT_SECRET=geoid-api-secret
