# Single source of truth for DB reset policy.
# Sourced by src/dynastore/scripts/db_reset.sh.  Python cleanup helpers may import these
# values in the future (parse with shlex) — keep the format shell-compatible.
#
# PRESERVED_SCHEMAS  — schemas never dropped by `db_reset.sh reset`.
#   pg_catalog / information_schema / pg_toast : postgres internals
#   cron                                       : pg_cron metadata (job rows wiped selectively)
#   public                                     : standard default schema
#   keycloak                                   : seeded once by /docker-entrypoint-initdb.d/003_keycloak.sql;
#                                                dropping it breaks keycloak on restart
#
# SYSTEM_CRON_JOBS  — rows in cron.job that survive a `reset`.  All other jobs
#   are app-owned per-tenant ({purpose}_{schema}) and are re-registered on module
#   startup via check-unschedule-reschedule; safe to wipe.
PRESERVED_SCHEMAS="pg_catalog information_schema pg_toast cron public keycloak"
SYSTEM_CRON_JOBS="system_cleanup_orphaned_cron_jobs monthly_cleanup_system_logs"
