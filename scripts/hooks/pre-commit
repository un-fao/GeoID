#!/bin/bash
# Auto-bump patch version on direct commits to main.
# Skips during rebase to avoid multiple bumps per replayed commit.
# PR merges to main are handled by .github/workflows/version-bump.yml.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Skip during rebase (replaying commits would bump N times)
if [ -d "$REPO_ROOT/.git/rebase-merge" ] || \
   [ -d "$REPO_ROOT/.git/rebase-apply" ]; then
    exit 0
fi

# Only bump on main
BRANCH="$(git branch --show-current)"
if [ "$BRANCH" != "main" ]; then
    exit 0
fi

"$REPO_ROOT/scripts/bump-version.sh"
git add "$REPO_ROOT/VERSION"
